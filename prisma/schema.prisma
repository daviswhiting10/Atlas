generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// WORKSPACE (tenant root)
// ─────────────────────────────────────────────

model Workspace {
  id                 String                @id @default(cuid())
  name               String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  users              User[]
  clientProfiles     ClientProfile[]
  leads              Lead[]
  outreachMessages   OutreachMessage[]
  methodology        MethodologyDocument[]
  observations       TrainerObservation[]
  exercises          Exercise[]
  workouts           Workout[]
  conversations      Conversation[]
  usageLogs          UsageLog[]
  programs           Program[]
  programAssignments ProgramAssignment[]
}

// ─────────────────────────────────────────────
// AUTH (Auth.js v5 required models)
// ─────────────────────────────────────────────

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  image          String?
  role           Role            @default(TRAINER)
  workspaceId    String?
  workspace      Workspace?      @relation(fields: [workspaceId], references: [id])
  accounts       Account[]
  sessions       Session[]
  trainerProfile TrainerProfile?
  clientProfile  ClientProfile?  @relation("ClientUser")
  sentMessages   Message[]
  usageLogs      UsageLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum Role {
  TRAINER
  CLIENT
  ADMIN
}

// ─────────────────────────────────────────────
// PROFILES
// ─────────────────────────────────────────────

model TrainerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  bio            String?  @db.Text
  certifications Json?
  voiceProfile   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ClientProfile {
  id                 String              @id @default(cuid())
  workspaceId        String
  workspace          Workspace           @relation(fields: [workspaceId], references: [id])
  userId             String?             @unique // null until client onboards to the app
  user               User?               @relation("ClientUser", fields: [userId], references: [id])
  fullName           String
  email              String?
  phone              String?
  dob                DateTime?
  primaryGoal        String?
  status             ClientStatus        @default(PROSPECT)
  retentionScore     Int?
  retentionFlag      String?
  lastContactAt      DateTime?
  deletedAt          DateTime?
  intakeForms        IntakeForm[]
  assessments        Assessment[]
  programAssignments ProgramAssignment[]
  sessionNotes       SessionNote[]
  outreachLog        OutreachMessage[]
  workoutLogs        WorkoutLog[]
  workouts           Workout[]
  nutritionEntries   NutritionEntry[]
  progressPhotos     ProgressPhoto[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  AT_RISK
  CHURNED
}

// ─────────────────────────────────────────────
// INTAKE & ASSESSMENT
// ─────────────────────────────────────────────

model IntakeForm {
  id         String        @id @default(cuid())
  clientId   String
  client     ClientProfile @relation(fields: [clientId], references: [id])
  sourceType String        @default("web-form")
  rawFileUrl String?
  parsedData Json
  aiSummary  String?       @db.Text
  redFlags   Json?
  createdAt  DateTime      @default(now())
}

model Assessment {
  id                 String        @id @default(cuid())
  clientId           String
  client             ClientProfile @relation(fields: [clientId], references: [id])
  type               String
  findings           Json
  correctiveProtocol Json?
  referralFlag       Boolean       @default(false)
  referralReason     String?
  createdAt          DateTime      @default(now())
}

// ─────────────────────────────────────────────
// EXERCISE LIBRARY
// ─────────────────────────────────────────────

enum MovementPattern {
  SQUAT
  HINGE
  HORIZONTAL_PUSH
  VERTICAL_PUSH
  HORIZONTAL_PULL
  VERTICAL_PULL
  LUNGE
  CARRY
  ROTATION
  ANTI_ROTATION
  LOCOMOTION
}

model Exercise {
  id                String                    @id @default(cuid())
  workspaceId       String? // null = global library
  workspace         Workspace?                @relation(fields: [workspaceId], references: [id])
  name              String
  slug              String                    @unique
  movementPattern   MovementPattern
  primaryMuscles    Json // String[]
  secondaryMuscles  Json // String[]
  equipment         String
  instructions      Json // String[]
  gifUrl            String?
  videoUrl          String?
  coachingCues      String[]                  @default([])
  regression        String?
  progression       String?
  workoutExercises  WorkoutExercise[]
  assignedExercises AssignedWorkoutExercise[]
  createdAt         DateTime                  @default(now())
}

// Workout: used both as a standalone template (blockId=null) and as part of a Block (blockId set)
model Workout {
  id           String          @id @default(cuid())
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id])
  blockId      String?
  block        Block?          @relation(fields: [blockId], references: [id], onDelete: Cascade)
  clientId     String?
  client       ClientProfile?  @relation(fields: [clientId], references: [id])
  name         String
  dayOfWeek    Int? // 1–7; null for standalone templates
  order        Int? // position within block
  isTemplate   Boolean         @default(false)
  templateName String?
  templateTags Json? // { goal, split, level, equipment }
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  exercises    WorkoutExercise[]
}

model WorkoutExercise {
  id             String   @id @default(cuid())
  workspaceId    String
  workoutId      String
  exerciseId     String
  order          Int
  prescribedSets Json // SetShape[]
  notes          String?  @db.Text

  workout        Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise       Exercise @relation(fields: [exerciseId], references: [id])

  @@index([workoutId, order])
}

// ─────────────────────────────────────────────
// PROGRAMS (workspace-level templates)
// ─────────────────────────────────────────────

model Program {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  name          String
  description   String?   @db.Text
  goalTags      Json? // { goals: string[], conditions: string[] }
  durationWeeks Int // stored for query convenience; should equal sum of block.weeks
  isTemplate    Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  blocks      Block[]
  assignments ProgramAssignment[]

  @@index([workspaceId, deletedAt])
}

model Block {
  id          String    @id @default(cuid())
  workspaceId String
  programId   String
  name        String
  order       Int // position within program (1-indexed)
  weeks       Int // duration in weeks

  program     Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  workouts    Workout[]

  @@index([programId, order])
}

// ─────────────────────────────────────────────
// PROGRAM ASSIGNMENTS (client snapshots)
// ─────────────────────────────────────────────

model ProgramAssignment {
  id              String           @id @default(cuid())
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  clientId        String
  client          ClientProfile    @relation(fields: [clientId], references: [id])
  sourceProgramId String
  sourceProgram   Program          @relation(fields: [sourceProgramId], references: [id])
  name            String // copied from Program.name at assignment time; editable
  startDate       DateTime
  status          AssignmentStatus @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  assignedWorkouts AssignedWorkout[]

  @@index([workspaceId, clientId, status])
}

enum AssignmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

model AssignedWorkout {
  id                  String        @id @default(cuid())
  workspaceId         String
  programAssignmentId String
  sourceWorkoutId     String? // FK to template Workout for traceability; null for ad-hoc
  name                String
  scheduledDate       DateTime
  loggedBy            LoggedBy      @default(TRAINER)
  status              WorkoutStatus @default(PLANNED)
  order               Int
  notes               String?       @db.Text

  programAssignment ProgramAssignment         @relation(fields: [programAssignmentId], references: [id], onDelete: Cascade)
  exercises         AssignedWorkoutExercise[]

  @@index([programAssignmentId, scheduledDate])
}

enum LoggedBy {
  TRAINER
  CLIENT
}

enum WorkoutStatus {
  PLANNED
  LOGGED
  SKIPPED
  RESCHEDULED
}

model AssignedWorkoutExercise {
  id                String  @id @default(cuid())
  workspaceId       String
  assignedWorkoutId String
  exerciseId        String
  order             Int
  prescribedSets    Json // SetShape[]
  notes             String? @db.Text

  assignedWorkout AssignedWorkout @relation(fields: [assignedWorkoutId], references: [id], onDelete: Cascade)
  exercise        Exercise        @relation(fields: [exerciseId], references: [id])

  @@index([assignedWorkoutId, order])
}

// ─────────────────────────────────────────────
// WORKOUT LOGGING (Week 2 — stubs kept for FK hygiene)
// ─────────────────────────────────────────────

model WorkoutLog {
  id          String        @id @default(cuid())
  clientId    String
  client      ClientProfile @relation(fields: [clientId], references: [id])
  date        DateTime
  durationMin Int?
  rpeAvg      Float?
  clientNotes String?       @db.Text
  trainerSeen Boolean       @default(false)
  sets        SetLog[]
  createdAt   DateTime      @default(now())
}

model SetLog {
  id           String     @id @default(cuid())
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id])
  setNumber    Int
  weight       Float?
  reps         Int?
  completed    Boolean    @default(true)
  createdAt    DateTime   @default(now())
}

// ─────────────────────────────────────────────
// SESSION NOTES
// ─────────────────────────────────────────────

model SessionNote {
  id             String        @id @default(cuid())
  clientId       String
  client         ClientProfile @relation(fields: [clientId], references: [id])
  date           DateTime
  rawInput       String        @db.Text
  structuredNote Json
  rpeAvg         Float?
  createdAt      DateTime      @default(now())
}

// ─────────────────────────────────────────────
// NUTRITION & PROGRESS PHOTOS
// ─────────────────────────────────────────────

model NutritionEntry {
  id           String        @id @default(cuid())
  clientId     String
  client       ClientProfile @relation(fields: [clientId], references: [id])
  date         DateTime
  mealType     String
  photoUrl     String?
  aiAnalysis   Json?
  manualMacros Json?
  notes        String?
  createdAt    DateTime      @default(now())
}

model ProgressPhoto {
  id        String        @id @default(cuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id])
  date      DateTime
  url       String
  angle     PhotoAngle
  stripped  Boolean       @default(false)
  createdAt DateTime      @default(now())
}

enum PhotoAngle {
  FRONT
  SIDE
  BACK
}

// ─────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────

model Conversation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  participants Json
  messages    Message[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  body           String       @db.Text
  attachments    Json?
  readBy         Json?
  createdAt      DateTime     @default(now())
}

// ─────────────────────────────────────────────
// LEADS & OUTREACH
// ─────────────────────────────────────────────

model Lead {
  id                  String            @id @default(cuid())
  workspaceId         String
  workspace           Workspace         @relation(fields: [workspaceId], references: [id])
  fullName            String
  email               String?
  phone               String?
  source              String
  context             String?           @db.Text
  status              LeadStatus        @default(NEW)
  convertedToClientId String?
  outreachLog         OutreachMessage[]
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  BOOKED
  CONVERTED
  DEAD
}

model OutreachMessage {
  id             String         @id @default(cuid())
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id])
  clientId       String?
  client         ClientProfile? @relation(fields: [clientId], references: [id])
  leadId         String?
  lead           Lead?          @relation(fields: [leadId], references: [id])
  channel        String
  purpose        String
  generatedDraft String         @db.Text
  sentVersion    String?        @db.Text
  sentAt         DateTime?
  reply          String?        @db.Text
  createdAt      DateTime       @default(now())
}

// ─────────────────────────────────────────────
// METHODOLOGY
// ─────────────────────────────────────────────

model MethodologyDocument {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  slug        String
  title       String
  appliesTo   Json
  content     String    @db.Text
  version     Int       @default(1)
  hash        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, slug])
}

// ─────────────────────────────────────────────
// SECOND BRAIN
// ─────────────────────────────────────────────

model TrainerObservation {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  context        String    @db.Text
  aiVersion      String    @db.Text
  trainerVersion String    @db.Text
  embedding      Bytes? // Phase 4: migrate to pgvector(1536)
  tags           Json
  createdAt      DateTime  @default(now())
}

// ─────────────────────────────────────────────
// USAGE LOGGING
// ─────────────────────────────────────────────

model UsageLog {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  feature      String
  model        String
  inputTokens  Int
  outputTokens Int
  costCents    Int
  latencyMs    Int?
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())
}
