generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Trainer {
  id              String   @id @default(cuid())
  name            String
  email           String
  voiceProfile    String?
  methodologyHash String?
  createdAt       DateTime @default(now())
}

model Client {
  id             String            @id @default(cuid())
  fullName       String
  email          String?
  phone          String?
  status         ClientStatus      @default(PROSPECT)
  primaryGoal    String?
  intakeForms    IntakeForm[]
  assessments    Assessment[]
  programs       Program[]
  sessionNotes   SessionNote[]
  outreachLog    OutreachMessage[]
  retentionScore Int?
  retentionFlag  String?
  lastContactAt  DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  AT_RISK
  CHURNED
}

model IntakeForm {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  rawFilePath  String
  parsedData   String   // JSON stored as text in SQLite
  aiSummary    String?
  redFlags     String?  // JSON array stored as text
  createdAt    DateTime @default(now())
}

model Assessment {
  id                  String   @id @default(cuid())
  clientId            String
  client              Client   @relation(fields: [clientId], references: [id])
  type                String
  findings            String   // JSON stored as text
  correctiveProtocol  String?  // JSON stored as text
  referralFlag        Boolean  @default(false)
  referralReason      String?
  createdAt           DateTime @default(now())
}

model Program {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  name         String
  goal         String
  durationWeeks Int
  structure    String   // JSON stored as text
  notes        String?
  trainerEdits String?  // JSON stored as text
  status       String   @default("draft")
  createdAt    DateTime @default(now())
}

model SessionNote {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  date           DateTime
  rawInput       String
  structuredNote String   // JSON stored as text
  rpeAvg         Float?
  createdAt      DateTime @default(now())
}

model OutreachMessage {
  id             String    @id @default(cuid())
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id])
  leadId         String?
  lead           Lead?     @relation(fields: [leadId], references: [id])
  channel        String
  purpose        String
  generatedDraft String
  sentVersion    String?
  sentAt         DateTime?
  reply          String?
  createdAt      DateTime  @default(now())
}

model Lead {
  id          String            @id @default(cuid())
  fullName    String
  email       String?
  phone       String?
  source      String
  context     String?
  status      String            @default("new")
  outreachLog OutreachMessage[]
  createdAt   DateTime          @default(now())
}

model TrainerObservation {
  id             String   @id @default(cuid())
  context        String
  aiVersion      String
  trainerVersion String
  embedding      Bytes?
  tags           String   // JSON array stored as text
  createdAt      DateTime @default(now())
}
